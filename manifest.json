{
  "manifest_version": 2,
  "name": "FoxSS",
  "version": "1.0.0",
  "description": "Capture a screenshot of the entire web page. Long pages are automatically split into multiple images.",
  "author": "Samet Guler",
  "homepage_url": "https://github.com/Samet1771/webphoto",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "notifications"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "FoxSS — Capture full page",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "commands": {
    "capture-full-page": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Capture the full page"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "foxss@webphoto",
      "strict_min_version": "91.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
